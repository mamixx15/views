</div>
      <a href="/dashboard" class="text-xs text-dim hover:text-text transition-colors font-mono flex items-center gap-1">
        <span class="mi mi-xs">dashboard</span> View Dashboard
      </a>
    </div>
  </div>
<% } %>

<div class="max-w-6xl mx-auto px-5 py-8">
  <div class="grid md:grid-cols-[220px_1fr] gap-8">

    <!-- SIDEBAR -->
    <aside class="hidden md:block">
      <div class="sticky top-20 space-y-6">
        <!-- Search hint -->
        <div class="flex items-center gap-2 px-3 py-2 rounded-lg border border-border bg-surface text-xs text-dim font-mono cursor-default">
          <span class="mi mi-xs">search</span>
          <span>Ctrl + K to search</span>
        </div>

        <!-- Category nav -->
        <div>
          <p class="text-[10px] font-mono text-dim uppercase tracking-widest mb-2 px-1">Categories</p>
          <nav class="space-y-0.5" id="sidebar-nav">
