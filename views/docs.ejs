<%- include('partials/head', { title, settings }) %>
<%- include('partials/navbar') %>

<style>
.reveal { opacity:0; transform:translateY(16px); transition:opacity .4s ease, transform .4s ease; }
.reveal.visible { opacity:1; transform:translateY(0); }
.reveal-delay-1 { transition-delay:.07s; }
.reveal-delay-2 { transition-delay:.14s; }

/* Endpoint card */
.ep-card {
  background:#0e0e0e;
  border:1px solid #1e1e1e;
  border-radius:10px;
  overflow:hidden;
  transition:border-color .15s, box-shadow .15s;
}
.ep-card:hover { border-color:#2a2a2a; }
.ep-card.expanded { border-color:#2a2a2a; box-shadow:0 4px 24px rgba(0,0,0,.3); }

.ep-header {
  display:flex; align-items:center; gap:12px;
  padding:14px 18px; cursor:pointer; user-select:none;
}
.ep-header:hover { background:rgba(255,255,255,.02); }
.ep-body { border-top:1px solid #1a1a1a; padding:20px 18px; display:none; }

/* Params */
.param-label {
  font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600;
  letter-spacing:.08em; text-transform:uppercase; color:#666;
  display:flex; align-items:center; gap:5px; margin-bottom:6px;
}
.req-star { color:#f87171; font-size:14px; line-height:1; }
.param-input {
  width:100%; background:#080808; border:1px solid #222; border-radius:7px;
  color:#e5e5e5; font-family:'JetBrains Mono',monospace; font-size:13px;
  padding:10px 14px; outline:none; transition:border-color .15s;
}
.param-input::placeholder { color:#2a2a2a; }
.param-input:focus { border-color:#3a3a3a; box-shadow:0 0 0 3px rgba(255,255,255,.04); }

/* Execute */
.exec-btn {
  width:100%; padding:12px 16px; background:#ededed; color:#080808;
  font-weight:700; font-size:13px; letter-spacing:.04em; text-transform:uppercase;
  border:none; border-radius:8px; cursor:pointer;
  display:flex; align-items:center; justify-content:center; gap:8px;
  transition:background .15s, transform .1s;
}
.exec-btn:hover { background:#fff; }
.exec-btn:active { transform:scale(.99); }
.exec-btn:disabled { background:#2a2a2a; color:#555; cursor:not-allowed; }

.clear-btn {
  width:100%; padding:9px; background:transparent; color:#555;
  font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:.08em;
  text-transform:uppercase; border:1px solid #1e1e1e; border-radius:8px;
  cursor:pointer; transition:border-color .15s, color .15s;
}
.clear-btn:hover { border-color:#333; color:#888; }

/* Response */
.resp-panel { background:#080808; border:1px solid #1e1e1e; border-radius:8px; overflow:hidden; margin-top:14px; display:none; }
.resp-tabbar { display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #1a1a1a; }
.resp-tabs { display:flex; }
.resp-tab {
  padding:10px 16px; font-family:'JetBrains Mono',monospace; font-size:11px;
  font-weight:600; letter-spacing:.08em; text-transform:uppercase;
  color:#444; background:none; border:none; border-bottom:2px solid transparent;
  cursor:pointer; margin-bottom:-1px; transition:color .15s, border-color .15s;
}
.resp-tab:hover { color:#777; }
.resp-tab.is-active { color:#ededed; border-bottom-color:#ededed; }
.resp-meta { display:flex; align-items:center; gap:8px; padding:0 12px; }
.copy-res-btn { padding:5px; background:none; border:none; color:#444; cursor:pointer; border-radius:4px; display:flex; align-items:center; transition:color .15s; }
.copy-res-btn:hover { color:#aaa; }
.resp-pane { display:none; }
.resp-pane.active { display:block; }
.resp-pre { padding:16px; font-family:'JetBrains Mono',monospace; font-size:12px; line-height:1.75; overflow-x:auto; max-height:320px; overflow-y:auto; white-space:pre-wrap; word-break:break-all; color:#bbb; }
.j-key { color:#86efac; } .j-str { color:#fda4af; } .j-num { color:#fbbf24; } .j-bool { color:#60a5fa; } .j-null { color:#a78bfa; }
.header-row { display:flex; gap:12px; padding:5px 16px; font-family:'JetBrains Mono',monospace; font-size:11px; border-bottom:1px solid #111; }
.header-row:last-child { border-bottom:none; }
.h-name { color:#86efac; min-width:160px; flex-shrink:0; } .h-value { color:#888; word-break:break-all; }

/* Method badge */
.method-get  { color:#4ade80; background:rgba(74,222,128,.1); border:1px solid rgba(74,222,128,.2); padding:3px 10px; border-radius:4px; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; }
.method-badge-sm { display:inline-flex; align-items:center; padding:1px 5px; font-family:'JetBrains Mono',monospace; font-size:9px; font-weight:700; border-radius:3px; }

/* Status colors */
.s-ok  { color:#4ade80; background:rgba(74,222,128,.1); border:1px solid rgba(74,222,128,.2); padding:2px 8px; border-radius:4px; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600; }
.s-err { color:#f87171; background:rgba(239,68,68,.1); border:1px solid rgba(239,68,68,.2); padding:2px 8px; border-radius:4px; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600; }

.chev { transition:transform .2s ease; display:inline-flex; align-items:center; font-size:20px; }
.chev.open { transform:rotate(180deg); }

@keyframes spin { to { transform:rotate(360deg); } }
</style>

<!-- ── DOCS HEADER ──────────────────────────────────────────────────────────── -->
<section class="border-b border-border relative overflow-hidden">
  <div class="absolute inset-0 grid-bg opacity-50"></div>
  <% if (settings.bannerImage) { %>
    <div class="absolute inset-0"><img src="<%= settings.bannerImage %>" alt="" class="w-full h-full object-cover opacity-[0.04]"/></div>
  <% } %>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-bg pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-5 py-12">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
      <div class="fade-up">
        <div class="flex items-center gap-2 mb-3">
          <span class="badge badge-green text-[10px]">
            <span class="mi" style="font-size:8px;font-variation-settings:'FILL' 1,'wght' 700,'GRAD' 0,'opsz' 20">circle</span>
            <%= settings.header.status %>
          </span>
          <span class="badge badge-white text-[10px]"><%= settings.version %></span>
        </div>
        <h1 class="text-3xl font-bold text-white mb-2">API Reference</h1>
        <p class="text-dim text-sm max-w-lg"><%= settings.description %></p>
      </div>

      <!-- Quick stats -->
      <div class="fade-up-2 flex gap-4 shrink-0">
        <% var totalEps = 0; settings.categories.forEach(function(c){ totalEps += c.items.length; }); %>
        <div class="text-center">
          <div class="text-2xl font-bold text-white"><%= totalEps %></div>
          <div class="text-[10px] font-mono text-dim uppercase tracking-wider">Endpoints</div>
        </div>
        <div class="w-px bg-border"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-white"><%= settings.categories.length %></div>
          <div class="text-[10px] font-mono text-dim uppercase tracking-wider">Categories</div>
        </div>
        <div class="w-px bg-border"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-success">Free</div>
          <div class="text-[10px] font-mono text-dim uppercase tracking-wider">To Start</div>
        </div>
      </div>
    </div>

    <!-- Base URL pill -->
    <div class="mt-6 fade-up-3 flex items-center gap-3 flex-wrap">
      <span class="text-xs text-dim font-mono">Base URL:</span>
      <code class="text-xs font-mono text-soft bg-card border border-border px-3 py-1.5 rounded-lg">
        https://nexapi.fun/api
      </code>
