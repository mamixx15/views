<%- include('partials/head', { title, settings }) %>
<%- include('partials/navbar') %>

<div class="min-h-[calc(100vh-56px)] flex items-center justify-center px-5 py-16">
  <div class="w-full max-w-sm fade-up">
    <div class="text-center mb-8">
      <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center mx-auto mb-4">
        <span class="mi text-bg" style="font-size:20px;font-variation-settings:'FILL' 1,'wght' 600,'GRAD' 0,'opsz' 24">person_add</span>
      </div>
      <h1 class="text-xl font-bold text-white">Create account</h1>
      <p class="text-dim text-sm mt-1">Free forever. API key included.</p>
    </div>

    <div class="card p-6">
      <form action="/auth/register" method="POST" novalidate class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-dim mb-1.5 flex items-center gap-1">
            <span class="mi mi-xs">alternate_email</span> Username
          </label>
          <input type="text" name="username" required autocomplete="username"
            value="<%= typeof old !== 'undefined' && old.username ? old.username : '' %>"
            placeholder="yourname" class="input" />
        </div>

        <div>
          <label class="block text-xs font-medium text-dim mb-1.5 flex items-center gap-1">
            <span class="mi mi-xs">mail</span> Email address
          </label>
          <input type="email" name="email" required autocomplete="email"
            value="<%= typeof old !== 'undefined' && old.email ? old.email : '' %>"
            placeholder="you@example.com" class="input" />
        </div>

        <div>
          <label class="block text-xs font-medium text-dim mb-1.5 flex items-center gap-1">
            <span class="mi mi-xs">lock</span> Password
          </label>
          <div class="relative">
            <input type="password" name="password" id="pw1" required autocomplete="new-password" placeholder="Min. 8 characters" class="input pr-10" />
            <button type="button" onclick="togglePw('pw1','eye1')" class="absolute right-3 top-1/2 -translate-y-1/2 text-dim hover:text-soft transition-colors">
              <span class="mi mi-sm" id="eye1">visibility</span>
            </button>
          </div>
        </div>

        <div>
          <label class="block text-xs font-medium text-dim mb-1.5 flex items-center gap-1">
            <span class="mi mi-xs">lock_reset</span> Confirm password
          </label>
          <input type="password" name="confirm_password" required autocomplete="new-password" placeholder="Repeat password" class="input" />
        </div>

        <button type="submit" class="btn-primary w-full justify-center py-2.5">
          <span class="mi mi-sm">key</span> Create Account & Get API Key
        </button>
      </form>
    </div>

    <p class="text-center text-xs text-dim mt-6">
      Already registered? <a href="/auth/login" class="text-soft hover:text-white transition-colors ml-1">Sign in →</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
<script>
function togglePw(inputId, iconId) {
  const input  = document.getElementById(inputId);
  const icon   = document.getElementById(iconId);
  const isText = input.type === 'text';
  input.type   = isText ? 'password' : 'text';
  icon.textContent = isText ? 'visibility' : 'visibility_off';
}
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
  document.addEventListener('DOMContentLoaded', () => {
    Swal.fire({ toast:true, position:'top-end', timer:4500, showConfirmButton:false,
      icon:'error', title:'<%- error[0] %>',
      background:'#161616', color:'#ededed', iconColor:'#ef4444' });
  });
<% } %>
</script>
</body>
</html>
