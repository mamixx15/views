<%- include('partials/head', { title, settings }) %>
<%- include('partials/navbar') %>

<div class="max-w-3xl mx-auto px-5 py-10">

  <!-- Overall status banner -->
  <div class="mb-8 fade-up">
    <% if (overallStatus === 'operational') { %>
      <div class="card p-5 flex items-center gap-4" style="border-color:rgba(34,197,94,0.3);background:rgba(34,197,94,0.04)">
        <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background:rgba(34,197,94,0.15)">
          <span class="mi mi-md text-success">check_circle</span>
        </div>
        <div>
          <p class="font-bold text-white">All Systems Operational</p>
          <p class="text-dim text-xs mt-0.5">All endpoints are running normally.</p>
        </div>
      </div>
    <% } else if (overallStatus === 'degraded') { %>
      <div class="card p-5 flex items-center gap-4" style="border-color:rgba(251,191,36,0.3);background:rgba(251,191,36,0.04)">
        <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background:rgba(251,191,36,0.15)">
          <span class="mi mi-md" style="color:#fbbf24">warning</span>
        </div>
        <div>
          <p class="font-bold text-white">Partial Degradation</p>
          <p class="text-dim text-xs mt-0.5">Some endpoints are experiencing issues.</p>
        </div>
      </div>
    <% } else { %>
      <div class="card p-5 flex items-center gap-4" style="border-color:rgba(239,68,68,0.3);background:rgba(239,68,68,0.04)">
        <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background:rgba(239,68,68,0.15)">
          <span class="mi mi-md text-danger">error</span>
        </div>
        <div>
          <p class="font-bold text-white">Service Disruption</p>
          <p class="text-dim text-xs mt-0.5">One or more endpoints are currently down.</p>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-3 gap-3 mb-8 fade-up">
    <div class="card p-4 text-center">
      <div class="text-xl font-bold text-white"><%= totalCalls.toLocaleString() %></div>
      <div class="text-xs text-dim mt-1">Total Requests</div>
    </div>
    <div class="card p-4 text-center">
      <div class="text-xl font-bold text-white"><%= todayCalls.toLocaleString() %></div>
      <div class="text-xs text-dim mt-1">Today</div>
    </div>
    <div class="card p-4 text-center">
      <div class="text-xl font-bold text-white"><%= totalUsers.toLocaleString() %></div>
      <div class="text-xs text-dim mt-1">Users</div>
    </div>
  </div>

  <!-- Endpoint list -->
  <div class="fade-up-2">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-semibold text-white text-sm flex items-center gap-2">
        <span class="mi mi-sm text-dim">api</span> Endpoints
      </h2>
      <span class="text-xs font-mono text-dim" id="last-updated">Updated just now</span>
    </div>

    <%
      var cats = {};
      endpoints.forEach(function(ep) {
        if (!cats[ep.category]) cats[ep.category] = [];
        cats[ep.category].push(ep);
      });
    %>

    <div class="space-y-3">
      <% Object.keys(cats).forEach(function(catName) { %>
        <div class="card overflow-hidden">
          <div class="px-4 py-3 border-b border-border flex items-center gap-2">
            <span class="mi mi-xs text-dim">folder_open</span>
            <span class="text-xs font-semibold text-soft uppercase tracking-wider"><%= catName %></span>
          </div>
          <% cats[catName].forEach(function(ep, i) { %>
            <div class="px-4 py-3 flex items-center gap-3 <%= i < cats[catName].length - 1 ? 'border-b border-border/50' : '' %>">
              <!-- Status indicator -->
              <div class="w-2 h-2 rounded-full shrink-0 <%
                if (ep.status === 'operational') { %>
                  bg-success
                <% } else if (ep.status === 'degraded') { %>
                  bg-warning
                <% } else if (ep.status === 'down') { %>
                  bg-danger
                <% } else { %>
                  bg-muted
                <% } %>"
                style="<%= ep.status === 'operational' ? 'animation:statusPulse 2s ease-in-out infinite' : '' %>">
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm text-white font-medium"><%= ep.name %></span>
                  <code class="text-xs font-mono text-dim hidden sm:inline"><%= ep.path %></code>
                </div>
                <% if (ep.message) { %>
                  <p class="text-xs text-dim mt-0.5"><%= ep.message %></p>
                <% } %>
              </div>

              <!-- Uptime -->
              <% if (ep.uptime !== null) { %>
                <div class="text-right shrink-0 hidden sm:block">
                  <div class="text-xs font-mono text-<%= ep.uptime >= 95 ? 'success' : ep.uptime >= 70 ? 'warning' : 'danger' %>">
                    <%= ep.uptime %>%
                  </div>
                  <div class="text-[10px] text-dim">uptime</div>
                </div>
              <% } %>

              <!-- Status badge -->
              <span class="badge text-[10px] shrink-0 <%
                if (ep.status === 'operational')   { %>badge-green<%
                } else if (ep.status === 'degraded') { %>badge-yellow<%
                } else if (ep.status === 'down')     { %>badge-red<%
                } else { %>badge-white<% } %>">
                <%= ep.status === 'no_data' ? 'no data' : ep.status %>
              </span>
            </div>
          <% }) %>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Legend -->
  <div class="mt-8 flex flex-wrap gap-4 text-xs text-dim fade-up-3">
    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-success"></span> Operational</div>
    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-warning"></span> Degraded (&gt;30% errors/hr)</div>
    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-danger"></span> Down (&gt;70% errors/hr)</div>
    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-muted"></span> No recent data</div>
  </div>

  <p class="text-center text-xs text-muted font-mono mt-8">Auto-refreshes every 30 seconds</p>
</div>

<%- include('partials/footer') %>

<style>
  @keyframes statusPulse {
    0%,100% { opacity:1; box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
    50% { box-shadow: 0 0 0 5px rgba(34,197,94,0); }
  }
</style>
<script>
  // Auto-refresh every 30s
  var refreshTimer = 30;
  setInterval(function() {
    refreshTimer--;
    if (refreshTimer <= 0) {
      window.location.reload();
    } else {
      var el = document.getElementById('last-updated');
      if (el) el.textContent = 'Refreshes in ' + refreshTimer + 's';
    }
  }, 1000);
</script>
</body>
</html>
