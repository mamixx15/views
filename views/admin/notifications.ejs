<% var currentAdminPath = 'notifications'; var appSettings = {}; %>
<%- include('../partials/adminhead', { title, settings, user, currentAdminPath, appSettings }) %>

<div class="fade-up" style="display:flex;flex-direction:column;gap:14px">

  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <script>document.addEventListener('DOMContentLoaded',function(){Swal.fire({toast:true,position:'top-end',timer:3000,showConfirmButton:false,icon:'success',title:'<%- success[0] %>',background:'#111',color:'#ededed',iconColor:'#22c55e'});});</script>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <script>document.addEventListener('DOMContentLoaded',function(){Swal.fire({toast:true,position:'top-end',timer:3000,showConfirmButton:false,icon:'error',title:'<%- error[0] %>',background:'#111',color:'#ededed',iconColor:'#ef4444'});});</script>
  <% } %>

  <!-- Create form -->
  <div class="card">
    <div class="card-header"><span class="mi mi-sm">add_alert</span> Create Notification</div>
    <form action="/admin/notifications/create" method="POST" style="padding:16px;display:flex;flex-direction:column;gap:12px">
      <div class="form-row">
        <div>
          <label class="form-label">Title *</label>
          <input type="text" name="title" placeholder="Notification title" class="inp" required/>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
          <div>
            <label class="form-label">Type</label>
            <select name="type" class="inp">
              <option value="info">Info</option>
              <option value="warning">Warning</option>
              <option value="success">Success</option>
              <option value="danger">Danger</option>
            </select>
          </div>
          <div>
            <label class="form-label">Target</label>
            <select name="target" class="inp">
              <option value="all">All Users</option>
              <option value="user">Users Only</option>
              <option value="admin">Admins Only</option>
            </select>
          </div>
        </div>
      </div>
      <div>
        <label class="form-label">Message *</label>
        <textarea name="message" placeholder="Notification message..." class="inp" required></textarea>
      </div>
      <div>
        <button type="submit" class="btn btn-white">
          <span class="mi mi-xs">send</span> Publish Notification
        </button>
      </div>
    </form>
  </div>

  <!-- Notifications list -->
  <div class="card">
    <div class="card-header" style="justify-content:space-between">
      <div style="display:flex;align-items:center;gap:8px">
        <span class="mi mi-sm">notifications</span> All Notifications
      </div>
      <span class="badge badge-white"><%= notifications.length %></span>
    </div>

    <% if (notifications.length === 0) { %>
      <p class="empty-msg">No notifications yet.</p>
    <% } %>

    <% notifications.forEach(function(n) {
      var typeCls = { info:'badge-blue', warning:'badge-yellow', success:'badge-green', danger:'badge-red' };
      var typeIco = { info:'info', warning:'warning', success:'check_circle', danger:'error' };
      var cls = typeCls[n.type] || 'badge-blue';
      var ico = typeIco[n.type] || 'info';
    %>
      <div style="padding:14px 16px;border-bottom:1px solid #111;display:flex;gap:12px;align-items:flex-start">
        <div style="flex:1;min-width:0">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;flex-wrap:wrap">
            <span style="font-weight:600;font-size:13px;color:<%= n.is_active ? '#ededed' : '#444' %>">
              <%= n.title %>
            </span>
            <span class="badge <%= cls %>">
              <span class="mi mi-xs"><%= ico %></span> <%= n.type %>
            </span>
            <span class="badge badge-white">&rarr; <%= n.target %></span>
            <% if (!n.is_active) { %>
              <span class="badge badge-red">inactive</span>
            <% } %>
          </div>
          <p style="font-size:12px;color:#555;margin-bottom:4px"><%= n.message %></p>
          <p style="font-size:10px;font-family:'JetBrains Mono',monospace;color:#333">
            By <%= n.creator_name || 'system' %> &middot; <%= new Date(n.created_at).toLocaleString() %>
          </p>
        </div>
        <div style="display:flex;gap:4px;flex-shrink:0">
          <!-- Edit button — data attrs only, NO onclick -->
          <button
            type="button"
            class="btn btn-ghost edit-notif-btn"
            style="padding:5px 8px;font-size:11px"
            data-id="<%= n.id %>"
            data-title="<%= encodeURIComponent(n.title) %>"
            data-message="<%= encodeURIComponent(n.message) %>"
            data-type="<%= n.type %>"
            data-target="<%= n.target %>"
            data-active="<%= n.is_active %>"
          ><span class="mi mi-xs">edit</span></button>

          <!-- Delete button — data attrs only, NO onclick -->
          <button
            type="button"
            class="btn btn-danger del-notif-btn"
            style="padding:5px 8px;font-size:11px"
            data-id="<%= n.id %>"
          ><span class="mi mi-xs">delete</span></button>

          <!-- Hidden delete form -->
          <form action="/admin/notifications/<%= n.id %>/delete" method="POST" id="deln-<%= n.id %>" style="display:none"></form>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<!-- Hidden edit form -->
<form action="" method="POST" id="edit-notif-form" style="display:none">
  <input type="hidden" id="en-title"   name="title"/>
  <input type="hidden" id="en-message" name="message"/>
  <input type="hidden" id="en-type"    name="type"/>
  <input type="hidden" id="en-target"  name="target"/>
  <input type="hidden" id="en-active"  name="is_active"/>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {

  // ── Delete buttons ────────────────────────────────────────────────────────
  document.querySelectorAll('.del-notif-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = btn.dataset.id;
      Swal.fire({
        title: 'Delete notification?',
        icon: 'warning',
        background: '#111', color: '#ededed', iconColor: '#ef4444',
        showCancelButton: true,
        confirmButtonColor: '#ef4444', cancelButtonColor: '#1a1a1a',
        confirmButtonText: '<span style="font-size:12px;font-weight:600">Delete</span>',
        cancelButtonText:  '<span style="font-size:12px">Cancel</span>',
      }).then(function(r) {
        if (r.isConfirmed) {
          document.getElementById('deln-' + id).submit();
        }
      });
    });
  });

  // ── Edit buttons ──────────────────────────────────────────────────────────
  document.querySelectorAll('.edit-notif-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id      = btn.dataset.id;
      var title   = decodeURIComponent(btn.dataset.title);
      var message = decodeURIComponent(btn.dataset.message);
      var type    = btn.dataset.type;
      var target  = btn.dataset.target;
      var active  = btn.dataset.active;

      // Build select options with plain string concat — no template literals
      var typeOpts   = ['info','warning','success','danger'];
      var targetOpts = ['all','user','admin'];
      var targetLabels = { all:'All Users', user:'Users Only', admin:'Admins Only' };

      var typeSelHtml = typeOpts.map(function(t) {
        return '<option value="' + t + '"' + (type === t ? ' selected' : '') + '>' +
          t.charAt(0).toUpperCase() + t.slice(1) + '</option>';
      }).join('');

      var targetSelHtml = targetOpts.map(function(t) {
        return '<option value="' + t + '"' + (target === t ? ' selected' : '') + '>' +
          targetLabels[t] + '</option>';
      }).join('');

      var activeSelHtml =
        '<option value="1"' + (active == 1 ? ' selected' : '') + '>Active</option>' +
        '<option value="0"' + (active == 0 ? ' selected' : '') + '>Inactive</option>';

      var safeTitle   = title.replace(/"/g, '&quot;');
      var safeMessage = message.replace(/</g, '&lt;').replace(/>/g, '&gt;');

      var lbl = 'style="font-size:10px;font-family:\'JetBrains Mono\',monospace;' +
                'text-transform:uppercase;color:#555;letter-spacing:.06em;' +
                'display:block;margin-bottom:4px"';
      var inpStyle = 'style="font-size:12px;margin:0 0 0 0;width:100%"';

      var htmlContent =
        '<div style="text-align:left;display:flex;flex-direction:column;gap:10px">' +
          '<div>' +
            '<label ' + lbl + '>Title</label>' +
            '<input id="swal-title" class="swal2-input" ' + inpStyle + ' value="' + safeTitle + '"/>' +
          '</div>' +
          '<div>' +
            '<label ' + lbl + '>Message</label>' +
            '<textarea id="swal-msg" class="swal2-input" ' +
              'style="font-size:12px;height:80px;resize:vertical;margin:0;width:100%">' +
              safeMessage +
            '</textarea>' +
          '</div>' +
          '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px">' +
            '<div>' +
              '<label ' + lbl + '>Type</label>' +
              '<select id="swal-type" class="swal2-input" ' + inpStyle + '>' + typeSelHtml + '</select>' +
            '</div>' +
            '<div>' +
              '<label ' + lbl + '>Target</label>' +
              '<select id="swal-target" class="swal2-input" ' + inpStyle + '>' + targetSelHtml + '</select>' +
            '</div>' +
            '<div>' +
              '<label ' + lbl + '>Status</label>' +
              '<select id="swal-active" class="swal2-input" ' + inpStyle + '>' + activeSelHtml + '</select>' +
            '</div>' +
          '</div>' +
        '</div>';

      Swal.fire({
        title: 'Edit Notification',
        html: htmlContent,
        background: '#111', color: '#ededed',
        width: '520px',
        showCancelButton: true,
        confirmButtonColor: '#fff', cancelButtonColor: '#1a1a1a',
        confirmButtonText: '<span style="color:#080808;font-size:12px;font-weight:600">Save Changes</span>',
        cancelButtonText:  '<span style="font-size:12px">Cancel</span>',
        preConfirm: function() {
          var t = document.getElementById('swal-title').value.trim();
          var m = document.getElementById('swal-msg').value.trim();
          if (!t || !m) {
            Swal.showValidationMessage('Title and message are required.');
            return false;
          }
          return {
            title:   t,
            message: m,
            type:    document.getElementById('swal-type').value,
            target:  document.getElementById('swal-target').value,
            active:  document.getElementById('swal-active').value,
          };
        }
      }).then(function(r) {
        if (!r.isConfirmed) return;
        var f = document.getElementById('edit-notif-form');
        f.action = '/admin/notifications/' + id + '/edit';
        document.getElementById('en-title').value   = r.value.title;
        document.getElementById('en-message').value = r.value.message;
        document.getElementById('en-type').value    = r.value.type;
        document.getElementById('en-target').value  = r.value.target;
        document.getElementById('en-active').value  = r.value.active;
        f.submit();
      });
    });
  });

});
</script>

<%- include('../partials/admintail') %>
