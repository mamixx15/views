<% var currentAdminPath = 'users'; var appSettings = {}; %>
<%- include('../partials/adminhead', { title, settings, user, currentAdminPath, appSettings }) %>

<div class="fade-up" style="display:flex;flex-direction:column;gap:14px">

  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <script>document.addEventListener('DOMContentLoaded',function(){Swal.fire({toast:true,position:'top-end',timer:3000,showConfirmButton:false,icon:'success',title:'<%- success[0] %>',background:'#111',color:'#ededed',iconColor:'#22c55e'});});</script>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <script>document.addEventListener('DOMContentLoaded',function(){Swal.fire({toast:true,position:'top-end',timer:3000,showConfirmButton:false,icon:'error',title:'<%- error[0] %>',background:'#111',color:'#ededed',iconColor:'#ef4444'});});</script>
  <% } %>

  <div class="card">
    <div class="card-header" style="justify-content:space-between">
      <div style="display:flex;align-items:center;gap:8px"><span class="mi mi-sm">group</span> All Users</div>
      <span class="badge badge-white"><%= users.length %> users</span>
    </div>
    <div class="table-scroll">
      <table class="admin-table" style="min-width:700px">
        <thead><tr><th>#</th><th>Username</th><th>Email</th><th>Role</th><th>Tier</th><th>Status</th><th>Joined</th><th>Actions</th></tr></thead>
        <tbody>
          <% if (users.length === 0) { %>
            <tr><td colspan="8" class="empty-msg">No users yet.</td></tr>
          <% } else { users.forEach(function(u) { %>
            <tr id="row-<%= u.id %>">
              <td class="mono dim"><%= u.id %></td>
              <td style="font-weight:600;color:#ededed"><%= u.username %></td>
              <td class="dim" style="font-size:11px"><%= u.email %></td>
              <td>
                <span class="badge <%= u.role === 'admin' ? 'badge-blue' : 'badge-white' %>"><%= u.role %></span>
              </td>
              <td>
                <span class="badge <%= u.status === 'active' ? 'badge-green' : 'badge-red' %>"><%= u.status %></span>
              </td>
              <td class="mono dim" style="font-size:10px;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= u.api_key %>">
                <%= u.api_key.substring(0,18) %>...
              </td>
              <td>
                <div style="display:flex;gap:4px;flex-wrap:wrap">
                  <form action="/admin/users/<%= u.id %>/role" method="POST" style="display:inline">
                    <input type="hidden" name="role" value="<%= u.role === 'admin' ? 'user' : 'admin' %>"/>
                    <button type="submit" class="btn btn-ghost" style="padding:4px 8px;font-size:10px" title="<%= u.role === 'admin' ? 'Demote to user' : 'Promote to admin' %>">
                      <span class="mi mi-xs"><%= u.role === 'admin' ? 'person_remove' : 'admin_panel_settings' %></span>
                    </button>
                  </form>
                  <form action="/admin/users/<%= u.id %>/status" method="POST" style="display:inline">
                    <input type="hidden" name="status" value="<%= u.status === 'active' ? 'banned' : 'active' %>"/>
                    <button type="submit" class="btn <%= u.status === 'active' ? 'btn-danger' : 'btn-success' %>" style="padding:4px 8px;font-size:10px" title="<%= u.status === 'active' ? 'Ban user' : 'Unban user' %>">
                      <span class="mi mi-xs"><%= u.status === 'active' ? 'block' : 'check_circle' %></span>
                    </button>
                  </form>
                  <form action="/admin/users/<%= u.id %>/regen-key" method="POST" style="display:inline">
                    <button type="submit" class="btn btn-ghost" style="padding:4px 8px;font-size:10px" title="Regenerate API key">
                      <span class="mi mi-xs">refresh</span>
                    </button>
                  </form>
                  <button type="button" class="btn btn-ghost set-tier-btn" style="padding:4px 8px;font-size:10px"
                    data-id="<%= u.id %>" data-user="<%= u.username %>" data-tier="<%= u.tier %>" title="Set tier">
                    <span class="mi mi-xs">workspace_premium</span>
                  </button>
                  <form action="/admin/users/<%= u.id %>/tier" method="POST" id="tier-<%= u.id %>" style="display:none">
                    <input type="hidden" name="tier"     id="tier-val-<%= u.id %>"/>
                    <input type="hidden" name="duration" id="dur-val-<%= u.id %>"/>
                  </form>
                  <button type="button" class="btn btn-danger" style="padding:4px 8px;font-size:10px" onclick="confirmDelete(<%= u.id %>, '<%= u.username %>')" title="Delete user">
                    <span class="mi mi-xs">delete</span>
                  </button>
                  <form action="/admin/users/<%= u.id %>/delete" method="POST" id="del-<%= u.id %>" style="display:none"></form>
                </div>
              </td>
            </tr>
          <% }) } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.set-tier-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var id   = btn.dataset.id;
    var user = btn.dataset.user;
    var tier = btn.dataset.tier;
    var isPro = tier === 'pro';
    Swal.fire({
      title: 'Set Tier — ' + user,
      html:
        '<div style="text-align:left;display:flex;flex-direction:column;gap:10px">' +
        '<div>' +
        '<label style="font-size:10px;font-family:JetBrains Mono,monospace;text-transform:uppercase;color:#555;letter-spacing:.06em;display:block;margin-bottom:5px">Tier</label>' +
        '<select id="swal-tier" class="swal2-input" style="font-size:12px;margin:0;width:100%">' +
        '<option value="free"' + (!isPro ? ' selected' : '') + '>Free (100 req/day)</option>' +
        '<option value="pro"'  + ( isPro ? ' selected' : '') + '>Pro (10,000 req/day)</option>' +
        '</select>' +
        '</div>' +
        '<div id="swal-dur-wrap">' +
        '<label style="font-size:10px;font-family:JetBrains Mono,monospace;text-transform:uppercase;color:#555;letter-spacing:.06em;display:block;margin-bottom:5px">Duration (days, Pro only)</label>' +
        '<select id="swal-dur" class="swal2-input" style="font-size:12px;margin:0;width:100%">' +
        '<option value="7">7 days</option><option value="14">14 days</option><option value="30" selected>30 days</option>' +
        '</select>' +
        '</div>' +
        '</div>',
      background: '#111', color: '#ededed',
      showCancelButton: true, confirmButtonColor: '#fff', cancelButtonColor: '#1a1a1a',
      confirmButtonText: '<span style="color:#080808;font-size:12px;font-weight:600">Save Tier</span>',
      cancelButtonText: '<span style="font-size:12px">Cancel</span>',
      didOpen: function() {
        var sel = document.getElementById('swal-tier');
        var dur = document.getElementById('swal-dur-wrap');
        dur.style.display = sel.value === 'pro' ? 'block' : 'none';
        sel.addEventListener('change', function() { dur.style.display = sel.value === 'pro' ? 'block' : 'none'; });
      },
      preConfirm: function() {
        return { tier: document.getElementById('swal-tier').value, dur: document.getElementById('swal-dur').value };
      }
    }).then(function(r) {
      if (!r.isConfirmed) return;
      document.getElementById('tier-val-' + id).value = r.value.tier;
      document.getElementById('dur-val-'  + id).value = r.value.tier === 'pro' ? r.value.dur : '';
      document.getElementById('tier-' + id).submit();
    });
  });
});

function confirmDelete(id, name) {
  Swal.fire({
    title: 'Delete user?',
    html: '<span style="font-size:12px;color:#555">This will permanently delete <b style="color:#ededed">' + name + '</b> and all their data.</span>',
    icon: 'warning', background:'#111', color:'#ededed', iconColor:'#ef4444',
    showCancelButton:true, confirmButtonColor:'#ef4444', cancelButtonColor:'#1a1a1a',
    confirmButtonText:'<span style="font-size:12px;font-weight:600">Delete</span>',
    cancelButtonText:'<span style="font-size:12px">Cancel</span>',
  }).then(function(r) { 
    if(r.isConfirmed) document.getElementById('del-'+id).submit(); 
  });
}
</script>

<%- include('../partials/admintail') %>
