<% var currentAdminPath = 'analytics'; var appSettings = appSettings || {}; %>
<%- include('../partials/adminhead', { title, settings, user, currentAdminPath, appSettings }) %>

<div class="fade-up" style="display:flex;flex-direction:column;gap:14px">

  <!-- Charts row -->
  <div class="grid-2col">
    <div class="card">
      <div class="card-header"><span class="mi mi-sm">show_chart</span> API Calls — Last 30 Days</div>
      <div style="padding:16px;height:200px;position:relative">
        <canvas id="chart-calls"></canvas>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><span class="mi mi-sm">person_add</span> New Users — Last 30 Days</div>
      <div style="padding:16px;height:200px;position:relative">
        <canvas id="chart-users"></canvas>
      </div>
    </div>
  </div>

  <div class="grid-2col">
    <!-- Success vs Error -->
    <div class="card" style="overflow:hidden">
      <div class="card-header"><span class="mi mi-sm">donut_large</span> Success vs Error Rate</div>
      <div style="padding:16px;display:flex;align-items:center;gap:20px">
        <div style="width:140px;height:140px;position:relative;flex-shrink:0">
          <canvas id="chart-sre"></canvas>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px" id="sre-stats">
          <div style="font-size:11px;color:#555">Loading...</div>
        </div>
      </div>
    </div>

    <!-- Top users -->
    <div class="card" style="overflow:hidden">
      <div class="card-header"><span class="mi mi-sm">leaderboard</span> Top Users by Usage</div>
      <div class="table-scroll">
        <table class="admin-table" id="top-users-table" style="min-width:300px">
          <thead><tr><th>Rank</th><th>Username</th><th>Tier</th><th>Calls</th></tr></thead>
          <tbody><tr><td colspan="4" class="empty-msg">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
Chart.defaults.color = '#444';
Chart.defaults.font.family = "'JetBrains Mono', monospace";
Chart.defaults.font.size   = 10;

document.addEventListener('DOMContentLoaded', function() {
  fetch('/admin/api/analytics-data')
    .then(function(r) { return r.json(); })
    .then(function(d) {

      // Calls per day
      new Chart(document.getElementById('chart-calls').getContext('2d'), {
        type: 'line',
        data: {
          labels: d.callsPerDay.labels,
          datasets: [{
            label: 'API Calls', data: d.callsPerDay.data,
            borderColor:'#fff', backgroundColor:'rgba(255,255,255,0.05)',
            borderWidth:2, fill:true, tension:0.4, pointRadius:2,
          }]
        },
        options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}},
          scales:{ x:{grid:{color:'#1a1a1a'},ticks:{color:'#444'}}, y:{grid:{color:'#1a1a1a'},ticks:{color:'#444'},beginAtZero:true} }
        }
      });

      // New users per day
      new Chart(document.getElementById('chart-users').getContext('2d'), {
        type: 'bar',
        data: {
          labels: d.newUsers.labels,
          datasets: [{
            label: 'New Users', data: d.newUsers.data,
            backgroundColor:'rgba(96,165,250,0.2)', borderColor:'rgba(96,165,250,0.5)',
            borderWidth:1, borderRadius:3,
          }]
        },
        options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}},
          scales:{ x:{grid:{color:'#1a1a1a'},ticks:{color:'#444'}}, y:{grid:{color:'#1a1a1a'},ticks:{color:'#444'},beginAtZero:true} }
        }
      });

      // Success vs error doughnut
      var sr = d.successRate;
      var total = (sr.success||0) + (sr.errors||0);
      var pct   = total > 0 ? Math.round((sr.success/total)*100) : 0;
      new Chart(document.getElementById('chart-sre').getContext('2d'), {
        type: 'doughnut',
        data: {
          labels: ['Success','Errors'],
          datasets:[{ data:[sr.success||0, sr.errors||0], backgroundColor:['rgba(34,197,94,0.7)','rgba(239,68,68,0.7)'], borderColor:['#166534','#991b1b'], borderWidth:1, hoverOffset:3 }]
        },
        options: { responsive:true, maintainAspectRatio:false, cutout:'65%', plugins:{legend:{display:false}} }
      });
      document.getElementById('sre-stats').innerHTML =
        '<div style="font-size:22px;font-weight:700;color:#fff">' + pct + '%</div>' +
        '<div style="font-size:11px;color:#555">Success rate</div>' +
        '<div style="margin-top:8px;display:flex;flex-direction:column;gap:4px">' +
        '<div style="display:flex;gap:8px;align-items:center"><span style="width:8px;height:8px;background:rgba(34,197,94,0.7);border-radius:50%;display:inline-block"></span><span style="font-size:11px;color:#666">' + (sr.success||0).toLocaleString() + ' OK</span></div>' +
        '<div style="display:flex;gap:8px;align-items:center"><span style="width:8px;height:8px;background:rgba(239,68,68,0.7);border-radius:50%;display:inline-block"></span><span style="font-size:11px;color:#666">' + (sr.errors||0).toLocaleString() + ' Errors</span></div>' +
        '</div>';

      // Top users table
      var tbody = document.getElementById('top-users-table').querySelector('tbody');
      if (d.topUsers && d.topUsers.length > 0) {
        tbody.innerHTML = d.topUsers.map(function(u, i) {
          return '<tr>' +
            '<td class="mono dim">' + (i+1) + '</td>' +
            '<td style="color:#ededed;font-weight:600">' + u.username + '</td>' +
            '<td><span class="badge ' + (u.tier==='pro'?'badge-purple':'badge-white') + '" style="font-size:10px">' + u.tier + '</span></td>' +
            '<td class="mono soft">' + u.calls.toLocaleString() + '</td>' +
          '</tr>';
        }).join('');
      } else {
        tbody.innerHTML = '<tr><td colspan="4" class="empty-msg">No data yet.</td></tr>';
      }
    })
    .catch(function() {});
});
</script>

<%- include('../partials/admintail') %>
