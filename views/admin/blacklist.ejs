<% var currentAdminPath = 'blacklist'; var appSettings = {}; %>
<%- include('../partials/adminhead', { title, settings, user, currentAdminPath, appSettings }) %>

<div class="fade-up" style="display:flex;flex-direction:column;gap:14px">

  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <script>document.addEventListener('DOMContentLoaded',function(){Swal.fire({toast:true,position:'top-end',timer:3000,showConfirmButton:false,icon:'success',title:'<%- success[0] %>',background:'#111',color:'#ededed',iconColor:'#22c55e'});});</script>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <script>document.addEventListener('DOMContentLoaded',function(){Swal.fire({toast:true,position:'top-end',timer:3000,showConfirmButton:false,icon:'error',title:'<%- error[0] %>',background:'#111',color:'#ededed',iconColor:'#ef4444'});});</script>
  <% } %>

  <!-- Add IP -->
  <div class="card">
    <div class="card-header"><span class="mi mi-sm">block</span> Blacklist an IP</div>
    <form action="/admin/blacklist/add" method="POST" style="padding:16px;display:flex;gap:10px;flex-wrap:wrap">
      <div style="flex:1;min-width:160px">
        <label class="form-label">IP Address *</label>
        <input type="text" name="ip" placeholder="e.g. 192.168.1.100" class="inp" required pattern="(\d{1,3}\.){3}\d{1,3}"/>
      </div>
      <div style="flex:2;min-width:200px">
        <label class="form-label">Reason</label>
        <input type="text" name="reason" placeholder="Why is this IP being blocked?" class="inp"/>
      </div>
      <div style="display:flex;align-items:flex-end">
        <button type="submit" class="btn btn-danger"><span class="mi mi-xs">block</span> Block IP</button>
      </div>
    </form>
  </div>

  <!-- List -->
  <div class="card">
    <div class="card-header" style="justify-content:space-between">
      <div style="display:flex;align-items:center;gap:8px"><span class="mi mi-sm">format_list_bulleted</span> Blacklisted IPs</div>
      <span class="badge badge-red"><%= list.length %> blocked</span>
    </div>
    <% if (list.length === 0) { %>
      <p class="empty-msg">No IPs blacklisted. ✅</p>
    <% } else { %>
      <div class="table-scroll">
        <table class="admin-table" style="min-width:500px">
          <thead><tr><th>IP Address</th><th>Reason</th><th>Blocked By</th><th>Date</th><th>Action</th></tr></thead>
          <tbody>
            <% list.forEach(function(item) { %>
              <tr>
                <td class="mono" style="color:#f87171;font-weight:600"><%= item.ip %></td>
                <td class="dim" style="font-size:12px"><%= item.reason || '—' %></td>
                <td class="mono dim"><%= item.blocked_by_name || 'system' %></td>
                <td class="mono dim" style="font-size:10px"><%= new Date(item.created_at).toLocaleString() %></td>
                <td>
                  <form action="/admin/blacklist/remove" method="POST" style="display:inline">
                    <input type="hidden" name="ip" value="<%= item.ip %>"/>
                    <button type="submit" class="btn btn-success" style="padding:4px 8px;font-size:11px">
                      <span class="mi mi-xs">check_circle</span> Unblock
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/admintail') %>
