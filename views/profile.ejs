<%- include('partials/head', { title, settings }) %>
<%- include('partials/navbar') %>

<div class="max-w-6xl mx-auto px-5 py-10">

  <!-- Header -->
  <div class="mb-8 fade-up">
    <p class="text-xs font-mono text-dim mb-1 flex items-center gap-1.5">
      <span class="mi mi-xs">dashboard</span> Dashboard
    </p>
    <h1 class="text-2xl font-bold text-white">
      Welcome back, <span class="text-soft"><%= user.username %></span>
    </h1>
  </div>

  <!-- Top Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">

    <!-- API Key — spans 2 cols on lg -->
    <div class="card p-5 sm:col-span-2 fade-up">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <span class="mi mi-sm text-dim">key</span>
          <p class="text-sm font-semibold text-white">API Key</p>
        </div>
        <span class="badge badge-green text-[10px] flex items-center gap-1">
          <span class="mi mi-fill" style="font-size:9px;font-variation-settings:'FILL' 1,'wght' 700,'GRAD' 0,'opsz' 20">circle</span> Active
        </span>
      </div>
      <p class="text-xs text-dim mb-3">Use as <code class="font-mono bg-surface px-1.5 py-0.5 rounded text-soft">?apikey=YOUR_KEY</code> on every request.</p>

      <div class="flex items-center gap-2 bg-bg border border-border rounded-lg px-4 py-3 mb-4">
        <span class="mi mi-xs text-dim shrink-0">vpn_key</span>
        <code id="api-key-val" class="font-mono text-sm text-soft flex-1 truncate select-all"><%= user.api_key %></code>
        <button type="button" id="copy-btn" class="btn-secondary text-xs px-2.5 py-1.5 shrink-0">
          <span class="mi mi-xs" id="copy-icon">content_copy</span>
          <span id="copy-label">Copy</span>
        </button>
      </div>

      <form action="/profile/regenerate-key" method="POST" id="regen-form">
        <button type="button" id="regen-btn" class="btn-danger w-full justify-center text-xs py-2.5">
          <span class="mi mi-sm">refresh</span> Regenerate Key
        </button>
      </form>
    </div>

    <!-- Stats -->
    <div class="card p-5 fade-up flex flex-col justify-between">
      <div class="flex items-center gap-2 mb-4">
        <span class="mi mi-sm text-dim">bar_chart</span>
        <p class="text-sm font-semibold text-white">Usage</p>
      </div>
      <div>
        <div class="text-4xl font-bold text-white mb-1"><%= totalCalls %></div>
        <div class="text-xs text-dim">Total API calls</div>
      </div>
      <a href="/docs" class="flex items-center gap-1.5 text-xs text-dim hover:text-text transition-colors mt-4">
        <span class="mi mi-xs">arrow_forward</span> Browse endpoints
      </a>
    </div>
  </div>

  <!-- Account + Quick Example -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <div class="card p-5 fade-up-2">
      <div class="flex items-center gap-2 mb-4">
        <span class="mi mi-sm text-dim">manage_accounts</span>
        <p class="text-sm font-semibold text-white">Account</p>
      </div>
      <dl class="space-y-3">
        <div class="flex items-center justify-between">
          <dt class="text-xs text-dim flex items-center gap-1.5"><span class="mi mi-xs">alternate_email</span> Username</dt>
          <dd class="text-xs font-semibold text-white"><%= user.username %></dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-xs text-dim flex items-center gap-1.5"><span class="mi mi-xs">mail</span> Email</dt>
          <dd class="text-xs text-soft truncate max-w-[180px]"><%= user.email %></dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-xs text-dim flex items-center gap-1.5"><span class="mi mi-xs">shield</span> Role</dt>
          <dd><span class="badge badge-blue text-[10px]"><%= user.role %></span></dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-xs text-dim flex items-center gap-1.5"><span class="mi mi-xs">calendar_today</span> Joined</dt>
          <dd class="text-xs font-mono text-soft"><%= new Date(user.created_at).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %></dd>
        </div>
      </dl>
    </div>

    <div class="card p-5 fade-up-2">
      <div class="flex items-center gap-2 mb-4">
        <span class="mi mi-sm text-dim">terminal</span>
        <p class="text-sm font-semibold text-white">Quick Example</p>
      </div>
      <div class="bg-bg border border-border rounded-lg overflow-hidden">
        <div class="flex items-center gap-1.5 px-3 py-2 border-b border-border">
          <div class="w-2 h-2 rounded-full bg-danger/50"></div>
          <div class="w-2 h-2 rounded-full bg-muted/50"></div>
          <div class="w-2 h-2 rounded-full bg-muted/50"></div>
        </div>
        <pre class="p-3 text-xs font-mono text-soft overflow-x-auto"><code>fetch('/api/ai/luminai'
  + '?text=Hello'
  + '&apikey=<%= user.api_key.substring(0,16) %>...'
)
.then(r => r.json())
.then(console.log);</code></pre>
      </div>
      <a href="/docs" class="flex items-center gap-1.5 mt-3 text-xs text-dim hover:text-text transition-colors">
        <span class="mi mi-xs">menu_book</span> View all endpoints →
      </a>
    </div>
  </div>

  <!-- Recent Logs -->
  <div class="fade-up-3">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <span class="mi mi-sm text-dim">history</span>
        <p class="text-sm font-semibold text-white">Recent Calls</p>
      </div>
      <span class="badge badge-white text-[10px]">Last 50</span>
    </div>

    <% if (logs.length === 0) { %>
      <div class="card p-12 text-center">
        <span class="mi mi-lg text-muted block mb-3">inbox</span>
        <p class="text-dim text-sm">No API calls yet.</p>
        <a href="/docs" class="text-xs text-soft hover:text-white transition-colors mt-1 inline-block">Try an endpoint →</a>
      </div>
    <% } else { %>
      <div class="card overflow-hidden">
        <div class="table-scroll">
          <table class="w-full text-xs min-w-[500px]">
            <thead class="bg-surface border-b border-border">
              <tr>
                <th class="px-4 py-3 text-left font-mono text-dim font-medium">Endpoint</th>
                <th class="px-4 py-3 text-left font-mono text-dim font-medium">Status</th>
                <th class="px-4 py-3 text-left font-mono text-dim font-medium">IP</th>
                <th class="px-4 py-3 text-left font-mono text-dim font-medium">Time</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              <% logs.forEach(log => { %>
                <tr class="hover:bg-white/[0.015] transition-colors">
                  <td class="px-4 py-2.5 font-mono text-soft"><%= log.endpoint %></td>
                  <td class="px-4 py-2.5">
                    <span class="badge text-[10px] <%= log.status >= 200 && log.status < 300 ? 'badge-green' : 'badge-red' %>">
                      <%= log.status %>
                    </span>
                  </td>
                  <td class="px-4 py-2.5 font-mono text-dim"><%= log.ip || '—' %></td>
                  <td class="px-4 py-2.5 font-mono text-dim whitespace-nowrap"><%= new Date(log.created_at).toLocaleString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

<script>
(function() {

  function fbCopy(text, cb) {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0';
    document.body.appendChild(ta);
    ta.focus(); ta.select();
    try { document.execCommand('copy'); if (cb) cb(); } catch(e) {}
    document.body.removeChild(ta);
  }

  function doCopy(text, cb) {
    if (window.isSecureContext && navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(cb).catch(function() { fbCopy(text, cb); });
    } else {
      fbCopy(text, cb);
    }
  }

  document.addEventListener('DOMContentLoaded', function() {

    // Flash toasts
    <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
      Swal.fire({ toast:true, position:'top-end', timer:4000, showConfirmButton:false,
        icon:'success', title:'<%- success[0] %>',
        background:'#161616', color:'#ededed', iconColor:'#22c55e' });
    <% } %>
    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      Swal.fire({ toast:true, position:'top-end', timer:4000, showConfirmButton:false,
        icon:'error', title:'<%- error[0] %>',
        background:'#161616', color:'#ededed', iconColor:'#ef4444' });
    <% } %>

    // Copy API Key
    var copyBtn = document.getElementById('copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var key = document.getElementById('api-key-val').textContent.trim();
        var lbl = document.getElementById('copy-label');
        var ico = document.getElementById('copy-icon');
        doCopy(key, function() {
          lbl.textContent = 'Copied!';
          ico.textContent = 'check';
          Swal.fire({ toast:true, position:'top-end', timer:2000, showConfirmButton:false,
            icon:'success', title:'API Key copied!',
            background:'#161616', color:'#ededed', iconColor:'#22c55e' });
          setTimeout(function() {
            lbl.textContent = 'Copy';
            ico.textContent = 'content_copy';
          }, 2000);
        });
      });
    }

    // Regenerate Key
    var regenBtn = document.getElementById('regen-btn');
    if (regenBtn) {
      regenBtn.addEventListener('click', function() {
        Swal.fire({
          title: 'Regenerate API Key?',
          html: '<span style="font-size:12px;color:#737373">Your current key will be <b style="color:#f87171">immediately invalidated</b>. All apps using it will break.</span>',
          icon: 'warning',
          background:'#161616', color:'#ededed', iconColor:'#ef4444',
          showCancelButton: true,
          confirmButtonColor: '#ef4444', cancelButtonColor: '#1f1f1f',
          confirmButtonText: '<span style="font-size:13px;font-weight:600">Yes, regenerate</span>',
          cancelButtonText: '<span style="font-size:13px">Cancel</span>',
        }).then(function(r) {
          if (r.isConfirmed) document.getElementById('regen-form').submit();
        });
      });
    }

  });

})();
</script>
</body>
</html>
