<%- include('partials/head', { title, settings }) %>
<%- include('partials/navbar') %>

<div class="max-w-3xl mx-auto px-5 py-14">
  <div class="card p-8 text-center fade-up">
    <div class="mb-6">
      <span class="badge badge-purple mb-4">Payment Pending</span>
      <h1 class="text-2xl font-bold text-white">Scan QRIS to Pay</h1>
      <p class="text-dim text-sm mt-2">
        Please complete your payment of
        <strong class="text-white">
          Rp<%= trx.amount.toLocaleString('id-ID') %>
        </strong>
      </p>
    </div>

    <!-- QRIS -->
    <div class="bg-white p-4 rounded-xl inline-block mb-8 shadow-lg shadow-purple-500/10">
      <img
        src="<%= trx.qr %>"
        alt="QRIS"
        class="w-64 h-64 object-contain"
      >
    </div>

    <div class="grid grid-cols-2 gap-4 mb-8 text-left max-w-sm mx-auto">
      <div class="text-dim text-xs font-mono">TRX ID</div>
      <div class="text-white text-xs font-mono text-right">
        <%= trx.trxId %>
      </div>

      <div class="text-dim text-xs font-mono">Plan</div>
      <div class="text-white text-xs font-mono text-right">
        <%= trx.plan %> (<%= trx.duration %> Days)
      </div>

      <div class="text-dim text-xs font-mono">Amount</div>
      <div class="text-white text-xs font-mono text-right">
        Rp<%= trx.amount.toLocaleString('id-ID') %>
      </div>

      <div class="text-dim text-xs font-mono">Expired</div>
      <div class="text-white text-xs font-mono text-right">
        <%= trx.expired %>
      </div>
    </div>

    <div class="flex flex-col gap-3 max-w-sm mx-auto">
      <button id="check-status" class="btn-primary w-full justify-center">
        <span class="mi mi-sm">verified</span>
        Check Payment Status
      </button>

      <p class="text-[10px] text-dim font-mono italic">
        Payment will be verified automatically.
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
document.getElementById('check-status').addEventListener('click', async () => {
    const btn = document.getElementById('check-status');
    const old = btn.innerHTML;

    btn.disabled = true;
    btn.innerHTML = '<span class="mi mi-sm animate-spin">sync</span> Checking...';

    try {
        const res = await fetch('/upgrade/check/<%= trx.trxId %>');
        const data = await res.json();

        if (data.status === 'SUCCESS') {
            await Swal.fire({
                title: 'Payment Success!',
                text: 'Your account has been upgraded to Pro.',
                icon: 'success',
                background: '#161616',
                color: '#fff',
                confirmButtonColor: '#7c3aed'
            });

            location.href = '/dashboard';
            return;
        }

        Swal.fire({
            title: 'Payment Pending',
            text: data.message || 'Payment belum diterima.',
            icon: 'info',
            background: '#161616',
            color: '#fff',
            confirmButtonColor: '#7c3aed'
        });

    } catch (err) {
        Swal.fire({
            title: 'Error',
            text: 'Gagal mengecek status pembayaran.',
            icon: 'error',
            background: '#161616',
            color: '#fff',
            confirmButtonColor: '#7c3aed'
        });
    }

    btn.disabled = false;
    btn.innerHTML = old;
});
</script>

</body>
</html>