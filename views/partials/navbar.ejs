<header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto px-5 h-14 flex items-center justify-between gap-4">

    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <div class="w-7 h-7 bg-white rounded-md flex items-center justify-center">
        <span class="mi" style="font-size:15px;color:#080808;font-variation-settings:'FILL' 1,'wght' 700,'GRAD' 0,'opsz' 20">bolt</span>
      </div>
      <span class="font-semibold text-sm text-white tracking-tight"><%= settings.name %></span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      <a href="/" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm transition-colors <%= currentPath === '/' ? 'text-white bg-card' : 'text-dim hover:text-text hover:bg-card' %>">
        <span class="mi mi-xs">house</span> Home
      </a>
      <a href="/docs" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm transition-colors <%= currentPath === '/docs' ? 'text-white bg-card' : 'text-dim hover:text-text hover:bg-card' %>">
        <span class="mi mi-xs">menu_book</span> Docs
      </a>
      <a href="/status" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm transition-colors <%= currentPath === '/status' ? 'text-white bg-card' : 'text-dim hover:text-text hover:bg-card' %>">
        <span class="mi mi-xs">monitor_heart</span> Status
      </a>
      <a href="/upgrade" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm transition-colors <%= currentPath === '/upgrade' ? 'text-white bg-card' : 'text-dim hover:text-text hover:bg-card' %>">
        <span class="mi mi-xs">workspace_premium</span> Pro
      </a>
      <a href="/changelog" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm transition-colors <%= currentPath === '/changelog' ? 'text-white bg-card' : 'text-dim hover:text-text hover:bg-card' %>">
        <span class="mi mi-xs">history</span> Changelog
      </a>
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <!-- Theme toggle -->
      <button id="theme-toggle" title="Toggle dark/light mode"
        style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;background:transparent;border:1px solid var(--c-border,#242424);border-radius:7px;cursor:pointer;color:var(--c-dim,#737373);transition:all .15s"
        onmouseover="this.style.borderColor='var(--c-muted,#3a3a3a)';this.style.color='var(--c-text,#ededed)'"
        onmouseout="this.style.borderColor='var(--c-border,#242424)';this.style.color='var(--c-dim,#737373)'"
      >
        <span class="mi mi-sm" id="theme-icon">light_mode</span>
      </button>

      <% if (user) { %>
        <% if (user.tier === 'pro') { %>
          <span class="badge badge-purple hidden sm:flex" style="font-size:10px">
            <span class="mi mi-xs">workspace_premium</span> Pro
          </span>
        <% } %>
        <a href="/dashboard" class="flex items-center gap-2 px-3 py-1.5 rounded-md text-sm border border-border hover:border-muted text-dim hover:text-text transition-colors">
          <span class="mi mi-xs">account_circle</span>
          <span class="font-mono text-xs hidden sm:inline"><%= user.username %></span>
        </a>
        <form action="/auth/logout" method="POST" id="logout-form">
          <button type="button" id="navbar-logout-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm text-dim hover:text-danger transition-colors">
            <span class="mi mi-xs">logout</span>
            <span class="hidden sm:inline">Logout</span>
          </button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="px-3 py-1.5 rounded-md text-sm text-dim hover:text-text transition-colors">Login</a>
        <a href="/auth/register" class="btn-primary text-xs px-3 py-1.5">
          <span class="mi mi-xs">key</span> Get Started
        </a>
      <% } %>
    </div>
  </div>
</header>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Theme toggle
  var themeBtn  = document.getElementById('theme-toggle');
  var themeIcon = document.getElementById('theme-icon');
  var isDark    = !document.documentElement.classList.contains('light');

  function applyTheme(dark) {
    if (dark) {
      document.documentElement.classList.remove('light');
      themeIcon.textContent = 'light_mode';
      localStorage.setItem('zarapi-theme', 'dark');
    } else {
      document.documentElement.classList.add('light');
      themeIcon.textContent = 'dark_mode';
      localStorage.setItem('zarapi-theme', 'light');
    }
  }

  // Set initial icon
  applyTheme(isDark);

  if (themeBtn) {
    themeBtn.addEventListener('click', function() {
      isDark = !isDark;
      applyTheme(isDark);
    });
  }

  var logoutBtn = document.getElementById('navbar-logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', function() {
      const isDark = !document.documentElement.classList.contains('light');
      Swal.fire({
        title:'Sign out?', text:'Your session will be ended.', icon:'question',
        background: isDark ? '#161616' : '#fff', 
        color: isDark ? '#ededed' : '#111', 
        iconColor: isDark ? '#ffffff' : '#000',
        showCancelButton:true, 
        confirmButtonColor: isDark ? '#ffffff' : '#000', 
        cancelButtonColor: isDark ? '#242424' : '#eee',
        confirmButtonText:`<span style="color:${isDark ? '#080808' : '#fff'};font-weight:600;font-size:13px">Sign out</span>`,
        cancelButtonText:`<span style="color:${isDark ? '#fff' : '#000'};font-size:13px">Cancel</span>`,
      }).then(function(r) { if(r.isConfirmed) document.getElementById('logout-form').submit(); });
    });
  }
});
</script>
